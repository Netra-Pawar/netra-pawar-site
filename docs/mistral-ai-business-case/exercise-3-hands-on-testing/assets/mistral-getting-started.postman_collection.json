						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{MISTRAL_API_KEY}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"model\": \"mistral-small-latest\",\n    \"messages\": [\n        {\n            \"role\": \"user\",\n            \"content\": \"Explain the concept of an API in one simple sentence.\"\n        }\n    ]\n}"
				},
				"url": {
					"raw": "https://api.mistral.ai/v1/chat/completions",
